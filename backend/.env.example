# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/campus-pay?retryWrites=true&w=majority


# Security Configurations
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
JWT_EXPIRE=7d

# WebAuthn / Biometrics (FIDO2)
RP_NAME=CAMPUS-PAY-App
RP_ID=localhost
ORIGIN=http://localhost:5173

# SendGrid Configuration
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@campuspay.com
